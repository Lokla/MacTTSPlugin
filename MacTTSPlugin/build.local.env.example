# Copy this file to build.local.env and adjust values for your machine.

# Absolute path to Advanced Combat Tracker.exe
ACT_REFERENCE_PATH="/Users/yourname/Library/Application Support/CrossOver/Bottles/YourBottle/drive_c/Program Files (x86)/Advanced Combat Tracker/Advanced Combat Tracker.exe"

# Build configuration: Debug or Release
BUILD_CONFIGURATION="Release"

# Optional explicit build tool. Leave empty to auto-detect (msbuild -> xbuild).
BUILD_TOOL=""
